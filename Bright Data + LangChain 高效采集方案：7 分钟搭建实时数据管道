# 加载.env文件中的环境变量
from dotenv import load_dotenv
# LangChain集成Bright Data的Web Scraper API
from langchain_brightdata import BrightDataWebScraperAPI
# LangChain集成OpenAI的大模型
from langchain_openai import ChatOpenAI
# 用于JSON文件读写
import json
# 用于捕获网络/API相关异常
import requests

# 加载环境变量（优先读取.env文件，其次系统环境变量）
load_dotenv()

def get_scraped_data(url, dataset_type):
    """
    通过Bright Data Web Scraper API采集指定URL的结构化数据
    :param url: 目标采集URL（如LinkedIn个人主页）
    :param dataset_type: Bright Data预定义的数据集类型（如linkedin_person_profile）
    :return: 结构化的采集结果（字典/列表）
    :raise: 捕获并抛出采集过程中的异常
    """
    try:
        # 初始化Bright Data爬虫客户端（自动读取BRIGHT_DATA_API_KEY）
        web_scraper_api = BrightDataWebScraperAPI()
        
        # 调用API采集数据（参数：目标URL + 数据集类型）
        results = web_scraper_api.invoke({
            "url": url,
            "dataset_type": dataset_type
        })
        
        # 校验采集结果是否为空
        if not results:
            raise ValueError("Bright Data采集结果为空，请检查URL或数据集类型")
        
        return results
    
    except requests.exceptions.RequestException as e:
        raise Exception(f"Bright Data API请求失败: {str(e)}")
    except Exception as e:
        raise Exception(f"数据采集异常: {str(e)}")

def evaluate_candidate_with_llm(scraped_data):
    """
    使用OpenAI大模型分析采集到的候选人数据，评估是否适配远程软件工程师岗位
    :param scraped_data: Bright Data采集的结构化数据
    :return: AI生成的评估结果（字符串）
    """
    try:
        # 初始化OpenAI客户端（自动读取OPENAI_API_KEY）
        llm = ChatOpenAI(
            model="gpt-4o-mini",  # 性价比高的轻量版GPT-4，可替换为gpt-3.5-turbo
            temperature=0.3,      # 降低随机性，让回答更严谨
            max_tokens=200         # 限制回答长度（适配150词要求）
        )
        
        # 构建提示词（明确任务+数据上下文+格式要求）
        prompt = f"""
        请评估该候选人是否适合远程软件工程师岗位，并说明原因。
        要求：回答不超过150个单词，语言简洁，逻辑清晰。
        
        候选人信息：
        {json.dumps(scraped_data, ensure_ascii=False, indent=2)}
        """
        
        # 调用LLM生成评估结果
        response = llm.invoke(prompt)
        
        return response.content.strip()
    
    except Exception as e:
        raise Exception(f"LLM评估异常: {str(e)}")

def export_to_json(data, file_name="analysis.json"):
    """
    将评估结果导出为JSON文件
    :param data: 待导出的字典数据
    :param file_name: 输出文件名
    """
    try:
        with open(file_name, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=4)
        print(f"✅ 数据已成功导出至 {file_name}")
    except Exception as e:
        raise Exception(f"JSON文件导出失败: {str(e)}")

# 主程序入口
if __name__ == "__main__":
    # 配置采集目标（可替换为任意支持的URL和数据集类型）
    TARGET_URL = "https://linkedin.com/in/antonello-zanini"
    DATASET_TYPE = "linkedin_person_profile"
    
    try:
        # 1. 数据采集阶段
        print(f"🔍 开始从 {TARGET_URL} 采集数据...")
        scraped_data = get_scraped_data(TARGET_URL, DATASET_TYPE)
        print("✅ 数据采集完成")
        
        # 2. LLM评估阶段
        print("\n🤖 正在调用ChatGPT评估候选人...")
        evaluation = evaluate_candidate_with_llm(scraped_data)
        print(f"✅ 评估完成：\n{evaluation}")
        
        # 3. 结果导出阶段
        print("\n💾 正在导出评估结果...")
        export_data = {
            "url": TARGET_URL,
            "scraped_data": scraped_data,  # 保留原始采集数据
            "evaluation": evaluation
        }
        export_to_json(export_data)
        
    except Exception as e:
        print(f"❌ 程序执行失败: {str(e)}")
代码核心逻辑解析
1. 数据采集层（Bright Data + LangChain）
BrightDataWebScraperAPI：LangChain 封装的 Bright Data 客户端，自动读取环境变量中的 API 密钥，无需手动拼接请求头；
dataset_type参数：Bright Data 预定义的数据集模板，示例中linkedin_person_profile会直接返回 LinkedIn 个人主页的结构化数据（姓名、工作经历、技能等），无需手动解析 HTML；
异常处理：捕获网络请求失败、采集结果为空等问题，保证程序鲁棒性。
2. AI 分析层（OpenAI + LangChain）
ChatOpenAI：LangChain 简化了 OpenAI 的调用流程，只需指定模型名称即可初始化客户端；
提示词设计：将结构化的采集数据传入提示词，明确要求 LLM 评估候选人适配性并限制回答长度，保证输出结果的实用性；
参数调优：temperature=0.3降低随机性，让评估结果更客观；max_tokens=200避免回答过长。
3. 结果输出层
保留原始采集数据：导出的 JSON 文件包含scraped_data（原始数据）和evaluation（AI 分析结果），便于后续二次分析；
编码优化：使用encoding="utf-8"和ensure_ascii=False，避免中文乱码。
